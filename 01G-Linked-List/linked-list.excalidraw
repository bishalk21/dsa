      "isDeleted": false,
      "boundElements": [],
      "updated": 1773385476542,
      "link": null,
      "locked": false,
      "text": "- check if index is valid, \n- reach index - 1 node and update its next to skip node at index\n  - link it to the new node 2 steps ahead\n- if index < 0 && index >= this.size, do nothing\n- if index === 0, update head to the next node\n- reduce size",
      "fontSize": 74.39982096354359,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- check if index is valid, \n- reach index - 1 node and update its next to skip node at index\n  - link it to the new node 2 steps ahead\n- if index < 0 && index >= this.size, do nothing\n- if index === 0, update head to the next node\n- reduce size",
      "autoResize": false,
      "lineHeight": 1.25
    },
